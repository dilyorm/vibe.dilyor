# --- Required ---
GEMINI_API_KEY=your_key_here

# Optional: override default model (gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-pro

# --- YouTube cookies (defeat "Sign in to confirm you're not a bot") ---
# EASIEST: drop a Netscape-format cookies.txt at the repo root or backend/.
# It is auto-detected. cookies.txt is gitignored.
#
# Or set ONE of these explicitly:
#
# Option A: read cookies from an installed browser
#   firefox | chrome | edge | brave | chromium | opera | vivaldi | safari
#   Append a profile after a colon: "firefox:Default"
YTDLP_COOKIES_FROM_BROWSER=

# Option B: explicit cookies.txt path (forward slashes on Windows)
YTDLP_COOKIES_FILE=
